{
  "manifest_version": 3,
  "name": "HouseApp",
  "version": "2.2.0",
  "description": "Notificações e resumo financeiro do HouseApp",
  "permissions": ["alarms", "notifications", "storage", "cookies"],
  "host_permissions": ["*://*/"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://app.jarvis.dev.br/*",
        "https://app.homolog.jarvis.dev.br/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
