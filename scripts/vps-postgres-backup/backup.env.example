# Example env for /opt/postgres-backup/backup.env
# Copy and adjust DATABASES / PEER_HOST / CONTAINER_FILTER / PG_USER per host.

PEER_HOST=ampliarme
CONTAINER_FILTER=postgres_postgres
PG_USER=postgres
KEEP_DAYS=7
BACKUP_ROOT=/var/backups/postgres
HOST_LABEL=jarvis

# Space-separated list of production databases only (no homolog).
DATABASES="houseapp_v2"
