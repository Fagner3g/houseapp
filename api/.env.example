# Jobs — em development os jobs de alerta ficam desligados por padrão
# Defina true para testar alertas/WhatsApp localmente
JOBS_ALERTS_ENABLED=

# Redirect all WhatsApp notifications to this number (dev/homolog only).
# Used by normalizePhone via DEV_PHONE_OVERRIDE — never set in production.
# Ex: 31999999999
DEV_PHONE_OVERRIDE=

BREVO_API_KEY=
MAIL_FROM_EMAIL=no-reply@houseapp.local
MAIL_FROM_NAME=HouseApp
# Optional legacy SMTP (unused when BREVO_API_KEY is set)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Brapi (cotações automáticas)
# Opcional para os 4 tickers gratuitos de teste (PETR4, VALE3, MGLU3, ITUB4)
# Necessário para FIIs e demais ativos suportados pela Brapi
BRAPI_TOKEN=

# Evolution API (WhatsApp) — required when running docker-compose evolution service
EVOLUTION_API_KEY=
