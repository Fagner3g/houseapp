    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.4",
    "tsup": "^8.3.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.3"
  },
  "dependencies": {
    "@houseapp/finance-core": "file:../packages/finance-core",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@getbrevo/brevo": "^3.0.1",
    "@paralleldrive/cuid2": "^2.2.2",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.3",
    "fastify": "^5.4.0",
    "fastify-type-provider-zod": "^5.0.2",
    "http-status-codes": "^2.3.0",
    "jose": "^6.0.12",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "pino-pretty": "^13.1.1",
    "postgres": "^3.4.7",
    "prom-client": "^15.1.3",
    "slugify": "^1.6.6",
    "xlsx": "^0.18.5",
    "zod": "^4.0.17"
  }
