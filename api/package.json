{
  "name": "houseapp",
  "version": "2.2.0",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --env-file ./.env src/http/server.ts",
    "db:repair-imported-statements": "tsx --env-file ./.env src/db/repair-imported-statements.ts",
    "db:backfill-statement-summaries": "tsx --env-file ./.env src/db/backfill-statement-summaries.ts",
    "db:repair-split-amounts": "tsx --env-file ./.env src/db/repair-split-amounts.ts",
    "db:clear-today-alert-notifications": "tsx --env-file ./.env scripts/clear-today-alert-notifications.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:split-whatsapp": "tsx --env-file ./.env src/scripts/test-split-whatsapp.ts",
    "db:up": "docker compose up pg -d",
    "db:down": "docker compose down",
    "build": "tsup",
    "start": "node dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
