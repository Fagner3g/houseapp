{
  "name": "houseapp-monorepo",
  "version": "1.0.25",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "test": "npm test --prefix api",
    "precommit": "lint-staged",
    "dev": "./web/node_modules/.bin/concurrently -n api,web -c blue,green \"cd api && npx tsx watch --env-file ./.env src/http/server.ts\" \"cd web && yarn dev\""
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.0"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,jsx,json,md}": "biome lint --fix"
  }
}
